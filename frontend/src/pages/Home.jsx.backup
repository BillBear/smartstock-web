import React, { useState } from 'react'
import {
  Layout,
  Input,
  Button,
  Select,
  Form,
  Row,
  Col,
  Card,
  message,
  Spin,
  Empty,
  Tabs,
} from 'antd'
import {
  SearchOutlined,
  StockOutlined,
  LineChartOutlined,
  BulbOutlined,
  RocketOutlined,
} from '@ant-design/icons'
import StockInfo from '../components/StockInfo'
import KLineChart from '../components/KLineChart'
import TechnicalPanel from '../components/TechnicalPanel'
import TechnicalIndicators from '../components/TechnicalIndicators'
import AdvicePanel from '../components/AdvicePanel'
import MoneyFlowPanel from '../components/MoneyFlowPanel'
import AIDecisionPanel from '../components/AIDecisionPanel'
import { stockApi, analysisApi, adviceApi, moneyFlowApi, aiDecisionApi } from '../services/api'
import { validateStockCode, getStockCodePlaceholder } from '../utils/format'
import './Home.css'

const { Header, Content, Footer } = Layout
const { Option } = Select

const Home = () => {
  const [form] = Form.useForm()
  const [loading, setLoading] = useState(false)
  const [stockData, setStockData] = useState(null)
  const [historyData, setHistoryData] = useState([])
  const [indicators, setIndicators] = useState(null)
  const [signalAnalysis, setSignalAnalysis] = useState(null)
  const [advice, setAdvice] = useState(null)
  const [moneyFlow, setMoneyFlow] = useState(null)
  const [aiDecision, setAiDecision] = useState(null)
  const [activeTab, setActiveTab] = useState('1')

  // 查询股票
  const handleSearch = async (values) => {
    const { symbol } = values

    if (!validateStockCode(symbol)) {
      message.error('请输入正确的6位股票代码')
      return
    }

    setLoading(true)
    setStockData(null)
    setHistoryData([])
    setIndicators(null)
    setSignalAnalysis(null)
    setAdvice(null)
    setMoneyFlow(null)
    setAiDecision(null)

    try {
      // 1. 获取实时行情
      const realtimeData = await stockApi.getRealtime(symbol)
      console.log('实时行情数据:', realtimeData)
      setStockData(realtimeData)

      // 2. 获取技术分析
      const technicalData = await analysisApi.technical({
        symbol,
        period: 'daily',
        days: 120,
      })

      setHistoryData(technicalData.history_data)
      setIndicators(technicalData.latest_indicators)

      // 3. 获取交易信号
      const signalData = await analysisApi.signal({ symbol })
      setSignalAnalysis(signalData.signal_analysis)

      // 4. 获取资金流向
      try {
        const flowData = await moneyFlowApi.getMoneyFlow({ symbol, days: 5 })
        setMoneyFlow(flowData)
      } catch (error) {
        console.error('获取资金流向失败:', error)
      }

      message.success('数据加载成功')
    } catch (error) {
      console.error('查询失败:', error)
      message.error('查询失败，请检查股票代码或稍后重试')
    } finally {
      setLoading(false)
    }
  }

  // Tab切换时自动加载数据
  const handleTabChange = async (key) => {
    setActiveTab(key)

    if (!stockData) return

    const values = form.getFieldsValue(['holding_period', 'risk_level', 'target_return'])

    // Tab 4: 投资建议
    if (key === '4' && !advice) {
      setLoading(true)
      try {
        const adviceData = await adviceApi.getAdvice({
          symbol: stockData.code,  // 修复：使用code而非symbol
          ...values,
        })
        setAdvice(adviceData)
        message.success('投资建议加载成功')
      } catch (error) {
        console.error('获取建议失败:', error)
        message.error('获取建议失败，请稍后重试')
      } finally {
        setLoading(false)
      }
    }

    // Tab 5: AI决策
    if (key === '5' && !aiDecision) {
      setLoading(true)
      try {
        const decisionData = await aiDecisionApi.getDecision({
          symbol: stockData.code,  // 修复：使用code而非symbol
          ...values,
        })
        setAiDecision(decisionData)
        message.success('AI决策加载成功')
      } catch (error) {
        console.error('获取AI决策失败:', error)
        message.error('获取AI决策失败，请稍后重试')
      } finally {
        setLoading(false)
      }
    }
  }

  // 移除原有的手动获取函数
  // const handleGetAdvice = async () => { ... }
  // const handleGetAIDecision = async () => { ... }

  return (
    <Layout className="app-layout">
      {/* 主内容 */}
      <Content className="app-content">
        <div className="content-wrapper">
          {/* 搜索区域 */}
          <Card className="search-card card-shadow" bordered={false}>
            <Form
              form={form}
              layout="vertical"
              onFinish={handleSearch}
              initialValues={{
                holding_period: 'medium',
                risk_level: 'medium',
                target_return: 15,
              }}
            >
              <Row gutter={16}>
                <Col xs={24} sm={12} md={8}>
                  <Form.Item
                    label="股票代码"
                    name="symbol"
                    rules={[{ required: true, message: '请输入股票代码' }]}
                  >
                    <Input
                      size="large"
                      placeholder={getStockCodePlaceholder()}
                      prefix={<SearchOutlined />}
                      allowClear
                    />
                  </Form.Item>
                </Col>
                <Col xs={24} sm={12} md={4}>
                  <Form.Item label="持有周期" name="holding_period">
                    <Select size="large">
                      <Option value="short">短期(1-7天)</Option>
                      <Option value="medium">中期(1-3月)</Option>
                      <Option value="long">长期(3月+)</Option>
                    </Select>
                  </Form.Item>
                </Col>
                <Col xs={24} sm={12} md={4}>
                  <Form.Item label="风险等级" name="risk_level">
                    <Select size="large">
                      <Option value="low">低风险</Option>
                      <Option value="medium">中等风险</Option>
                      <Option value="high">高风险</Option>
                    </Select>
                  </Form.Item>
                </Col>
                <Col xs={24} sm={12} md={4}>
                  <Form.Item label="目标收益(%)" name="target_return">
                    <Input size="large" type="number" min={0} max={100} />
                  </Form.Item>
                </Col>
                <Col xs={24} md={4}>
                  <Form.Item label=" ">
                    <Button
                      type="primary"
                      size="large"
                      icon={<SearchOutlined />}
                      htmlType="submit"
                      loading={loading}
                      block
                    >
                      查询分析
                    </Button>
                  </Form.Item>
                </Col>
              </Row>
            </Form>

            {/* 移除手动获取按钮，改为Tab自动加载 */}
          </Card>

          {/* 加载状态 */}
          {loading && (
            <div className="loading-container">
              <Spin size="large" tip="正在加载数据..." />
            </div>
          )}

          {/* 数据展示区域 */}
          {!loading && stockData && (
            <div className="data-section fade-in">
              {/* 股票信息 */}
              <StockInfo data={stockData} />

              {/* 标签页 */}
              <Tabs
                activeKey={activeTab}
                onChange={setActiveTab}
                size="large"
                items={[
                  {
                    key: '1',
                    label: (
                      <span>
                        <LineChartOutlined /> K线图表
                      </span>
                    ),
                    children: historyData.length > 0 && (
                      <KLineChart data={historyData} indicators={indicators} />
                    ),
                  },
                  {
                    key: '2',
                    label: (
                      <span>
                        <StockOutlined /> 技术指标
                      </span>
                    ),
                    children: historyData.length > 0 && indicators && (
                      <TechnicalIndicators data={historyData} indicators={indicators} />
                    ),
                  },
                  {
                    key: '3',
                    label: (
                      <span>
                        <RocketOutlined /> 交易信号
                      </span>
                    ),
                    children: signalAnalysis && (
                      <TechnicalPanel
                        indicators={indicators}
                        signalAnalysis={signalAnalysis}
                      />
                    ),
                  },
                  {
                    key: '4',
                    label: (
                      <span>
                        <BulbOutlined /> 投资建议
                      </span>
                    ),
                    children: advice ? (
                      <AdvicePanel advice={advice} />
                    ) : (
                      <Card className="card-shadow" bordered={false}>
                        <Empty
                          description='暂无投资建议，请点击上方"获取投资建议"按钮'
                          image={Empty.PRESENTED_IMAGE_SIMPLE}
                        />
                      </Card>
                    ),
                  },
                  {
                    key: '5',
                    label: (
                      <span>
                        <RocketOutlined /> AI决策
                      </span>
                    ),
                    children: (
                      <>
                        {moneyFlow && <MoneyFlowPanel data={moneyFlow} />}
                        {aiDecision ? (
                          <AIDecisionPanel data={aiDecision} />
                        ) : (
                          <Card className="card-shadow" bordered={false} style={{ marginTop: 16 }}>
                            <Empty
                              description='暂无AI决策，请点击上方"AI智能决策"按钮'
                              image={Empty.PRESENTED_IMAGE_SIMPLE}
                            />
                          </Card>
                        )}
                      </>
                    ),
                  },
                ]}
              />
            </div>
          )}

          {/* 空状态 */}
          {!loading && !stockData && (
            <Card className="empty-card card-shadow" bordered={false}>
              <Empty
                image={Empty.PRESENTED_IMAGE_SIMPLE}
                description={
                  <div>
                    <p>请输入股票代码开始分析</p>
                    <p className="empty-tips">
                      示例: 000001(平安银行)、600519(贵州茅台)、002594(比亚迪)
                    </p>
                  </div>
                }
              />
            </Card>
          )}
        </div>
      </Content>

      {/* 底部 */}
      <Footer className="app-footer">
        <div className="footer-content">
          <div>SmartStock AI © 2024 - 智能股票投资助手</div>
          <div className="footer-disclaimer">
            ⚠️ 免责声明: 本系统仅供学习参考，不构成投资建议。股市有风险，投资需谨慎。
          </div>
        </div>
      </Footer>
    </Layout>
  )
}

export default Home
